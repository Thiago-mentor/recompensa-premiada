rules_version = '2';

// SPARK_ECONOMY: alinhar com src/lib/constants/sparkEconomy.ts (modo grátis sem Functions)
// Ao migrar para Blaze: restrinja updates em users/wallet e volte a depender de Cloud Functions.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function sparkWelcomeCoins() {
      return 100;
    }

    function sparkOwnerUserPatch(userId) {
      return isOwner(userId)
        && resource.data.banido == false
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.username == resource.data.username
        && request.resource.data.codigoConvite == resource.data.codigoConvite
        && request.resource.data.convidadoPor == resource.data.convidadoPor
        && request.resource.data.email == resource.data.email
        && request.resource.data.banido == resource.data.banido
        && request.resource.data.riscoFraude == resource.data.riscoFraude
        && request.resource.data.criadoEm == resource.data.criadoEm
        && request.resource.data.rewardBalance == resource.data.rewardBalance
        && request.resource.data.nome is string
        && request.resource.data.nome.size() <= 120
        && (request.resource.data.foto is string || request.resource.data.foto == null)
        && request.resource.data.coins >= resource.data.coins
        && request.resource.data.coins <= resource.data.coins + 500
        && request.resource.data.gems >= resource.data.gems
        && request.resource.data.gems <= resource.data.gems + 500
        && request.resource.data.xp >= resource.data.xp
        && request.resource.data.xp <= resource.data.xp + 500
        && request.resource.data.level >= resource.data.level
        && request.resource.data.level <= resource.data.level + 5
        && request.resource.data.streakAtual <= 5000
        && request.resource.data.melhorStreak <= 5000
        && request.resource.data.totalPartidas >= resource.data.totalPartidas
        && request.resource.data.totalPartidas <= resource.data.totalPartidas + 5
        && request.resource.data.totalVitorias >= resource.data.totalVitorias
        && request.resource.data.totalVitorias <= resource.data.totalVitorias + 5
        && request.resource.data.totalDerrotas >= resource.data.totalDerrotas
        && request.resource.data.totalDerrotas <= resource.data.totalDerrotas + 5
        && request.resource.data.totalAdsAssistidos >= resource.data.totalAdsAssistidos
        && request.resource.data.totalAdsAssistidos <= resource.data.totalAdsAssistidos + 25
        && request.resource.data.scoreRankingDiario >= resource.data.scoreRankingDiario
        && request.resource.data.scoreRankingDiario <= resource.data.scoreRankingDiario + 500
        && request.resource.data.scoreRankingSemanal >= resource.data.scoreRankingSemanal
        && request.resource.data.scoreRankingSemanal <= resource.data.scoreRankingSemanal + 500
        && request.resource.data.scoreRankingMensal >= resource.data.scoreRankingMensal
        && request.resource.data.scoreRankingMensal <= resource.data.scoreRankingMensal + 500
        // Duelos PPT e timer de recuperação: só Cloud Functions (Admin SDK)
        && (!request.resource.data.keys().hasAny(['pptPvPDuelsRemaining'])
            || request.resource.data.pptPvPDuelsRemaining == resource.data.pptPvPDuelsRemaining)
        && (!request.resource.data.keys().hasAny(['pptPvpDuelsRefillAvailableAt'])
            || request.resource.data.pptPvpDuelsRefillAvailableAt == resource.data.pptPvpDuelsRefillAvailableAt)
        // Duelos Quiz e timer de recuperação: só Cloud Functions (Admin SDK)
        && (!request.resource.data.keys().hasAny(['quizPvPDuelsRemaining'])
            || request.resource.data.quizPvPDuelsRemaining == resource.data.quizPvPDuelsRemaining)
        && (!request.resource.data.keys().hasAny(['quizPvpDuelsRefillAvailableAt'])
            || request.resource.data.quizPvpDuelsRefillAvailableAt == resource.data.quizPvpDuelsRefillAvailableAt)
        // Duelos Reaction Tap e timer de recuperação: só Cloud Functions (Admin SDK)
        && (!request.resource.data.keys().hasAny(['reactionPvPDuelsRemaining'])
            || request.resource.data.reactionPvPDuelsRemaining == resource.data.reactionPvPDuelsRemaining)
        && (!request.resource.data.keys().hasAny(['reactionPvpDuelsRefillAvailableAt'])
            || request.resource.data.reactionPvpDuelsRefillAvailableAt == resource.data.reactionPvpDuelsRefillAvailableAt);
    }

    function sparkUserCreate(userId) {
      let d = request.resource.data;
      return isOwner(userId)
        && d.uid == userId
        && d.nome is string
        && d.nome.size() >= 2
        && d.username is string
        && d.username.size() >= 3
        && (d.email == null || d.email is string)
        && (d.foto == null || d.foto is string)
        && d.codigoConvite is string
        && d.codigoConvite.size() == 8
        && (d.convidadoPor == null || d.convidadoPor is string)
        && d.coins == sparkWelcomeCoins()
        && d.gems == 0
        && d.rewardBalance == 0
        && d.xp == 0
        && d.level == 1
        && d.streakAtual == 0
        && d.melhorStreak == 0
        && d.ultimaEntradaEm == null
        && d.totalAdsAssistidos == 0
        && d.totalPartidas == 0
        && d.totalVitorias == 0
        && d.totalDerrotas == 0
        && d.scoreRankingDiario == 0
        && d.scoreRankingSemanal == 0
        && d.scoreRankingMensal == 0
        && d.banido == false
        && d.riscoFraude == 'baixo';
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if sparkUserCreate(userId);
      allow update: if isAdmin() || sparkOwnerUserPatch(userId);
      allow delete: if false;
    }

    match /userMissions/{userId}/daily/{missionId} {
      allow read, write: if isOwner(userId);
    }

    match /userMissions/{userId}/weekly/{missionId} {
      allow read, write: if isOwner(userId);
    }

    match /missions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /wallet_transactions/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.moeda in ['coins', 'gems', 'rewardBalance']
        && request.resource.data.tipo is string
        && request.resource.data.descricao is string
        && request.resource.data.valor >= -500
        && request.resource.data.valor <= 500
        && request.resource.data.saldoApos >= -1000000
        && request.resource.data.saldoApos <= 10000000;
      allow update, delete: if false;
    }

    match /matches/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.gameId is string
        && request.resource.data.resultado in ['vitoria', 'derrota', 'empate']
        && request.resource.data.score >= 0
        && request.resource.data.score <= 1000
        && (!request.resource.data.keys().hasAny(['rewardCoins'])
            || (request.resource.data.rewardCoins is int
                && request.resource.data.rewardCoins >= 0
                && request.resource.data.rewardCoins <= 400))
        && (!request.resource.data.keys().hasAny(['rankingPoints'])
            || (request.resource.data.rankingPoints is int
                && request.resource.data.rankingPoints >= 0
                && request.resource.data.rankingPoints <= 150));
      allow update, delete: if false;
    }

    match /rankings_daily/{period}/entries/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    match /rankings_weekly/{period}/entries/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    match /rankings_monthly/{period}/entries/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    match /ad_events/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status is string;
      allow update, delete: if false;
    }

    match /reward_claims/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pendente'
        && request.resource.data.valor > 0;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /referrals/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /fraud_logs/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /system_configs/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /support_tickets/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /games/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Fila automática + salas 1v1 — escrita apenas via Cloud Functions
    match /matchmaking_queue/{gameId}/waiting/{waitUid} {
      allow read, write: if false;
    }

    match /game_rooms/{roomId} {
      allow read: if isSignedIn()
        && (resource.data.hostUid == request.auth.uid || resource.data.guestUid == request.auth.uid);
      allow write: if false;

      // Escolhas PPT só via Cloud Function (Admin SDK)
      match /ppt_picks/{pickUid} {
        allow read, write: if false;
      }
    }

    match /multiplayer_slots/{slotUid} {
      allow read: if isOwner(slotUid);
      allow write: if false;
    }
  }
}
