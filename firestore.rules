rules_version = '2';

// Firestore — modelo exclusivo Blaze + Cloud Functions (Admin SDK).
// Criação/alteração de economia, extrato, partidas, ranking, missões e anti-fraude
// só pelo backend. O cliente só lê o que precisa e abre chamadas HTTPS.
//
// Deploy: firebase deploy --only firestore:rules
// App Check: ative enforcement no Console para Firestore/Functions.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isClanMember(clanId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/clan_memberships/$(request.auth.uid))
        && get(/databases/$(database)/documents/clan_memberships/$(request.auth.uid)).data.clanId == clanId;
    }

    function isClanManager(clanId) {
      return isClanMember(clanId)
        && (
          get(/databases/$(database)/documents/clan_memberships/$(request.auth.uid)).data.role == "owner"
          || get(/databases/$(database)/documents/clan_memberships/$(request.auth.uid)).data.role == "leader"
        );
    }

    match /clan_memberships/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /clan_join_requests/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isClanManager(resource.data.clanId);
      allow list: if isAdmin() || isClanManager(resource.data.clanId);
      allow create, update, delete: if false;
    }

    match /clans/{clanId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;

      match /members/{memberUid} {
        allow read: if isClanMember(clanId) || isAdmin();
        allow create, update, delete: if false;
      }

      match /messages/{messageId} {
        allow read: if isClanMember(clanId) || isAdmin();
        allow create, update, delete: if false;
      }

      match /join_requests/{userId} {
        allow read: if isClanManager(clanId) || isOwner(userId) || isAdmin();
        allow create, update, delete: if false;
      }
    }

    // users: criado por initializeUserProfile (Admin); atualizado por Functions e admin.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /userMissions/{userId}/daily/{missionId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /userMissions/{userId}/weekly/{missionId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /missions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /wallet_transactions/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /raffles/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /raffle_purchases/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /matches/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /rankings_daily/{period}/entries/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /rankings_daily/{period}/games/{gameId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;

      match /entries/{uid} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }
    }

    match /rankings_weekly/{period}/entries/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /rankings_weekly/{period}/games/{gameId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;

      match /entries/{uid} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }
    }

    match /rankings_monthly/{period}/entries/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /rankings_monthly/{period}/games/{gameId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;

      match /entries/{uid} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }
    }

    match /clan_rankings_weekly/{period} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;

      match /entries/{clanId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }

      match /meta/{docId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }

      match /clans/{clanId}/contributors/{uid} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }
    }

    match /ad_events/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /reward_claims/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /referrals/{id} {
      allow get, list: if isAdmin();
      allow get: if isSignedIn()
        && (request.auth.uid == id
          || (resource != null && resource.data.inviterUserId == request.auth.uid));
      allow list: if isSignedIn()
        && resource.data.inviterUserId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /referral_campaigns/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /referral_rankings_daily/{period}/entries/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /referral_rankings_weekly/{period}/entries/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /referral_rankings_monthly/{period}/entries/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /referral_rankings_alltime/{period}/entries/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /fraud_logs/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /system_configs/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /user_chests/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false;

      match /items/{chestId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if false;
      }
    }

    match /quiz_questions/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /support_tickets/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /games/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /matchmaking_queue/{gameId}/waiting/{waitUid} {
      allow read, write: if false;
    }

    match /game_rooms/{roomId} {
      allow read: if isSignedIn()
        && (resource.data.hostUid == request.auth.uid || resource.data.guestUid == request.auth.uid);
      allow write: if false;

      match /ppt_picks/{pickUid} {
        allow read, write: if false;
      }
    }

    match /multiplayer_slots/{slotUid} {
      allow read: if isOwner(slotUid);
      allow write: if false;
    }
  }
}
